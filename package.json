{
  "name": "adaptive-media",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config web/vite.config.ts",
    "dev:nextbound": "vite --config web/nextbound.vite.config.ts",
    "dev:artifact": "vite --config web/artifact.vite.config.ts",
    "dev:feed": "vite --config web/artifact-feed.vite.config.ts",
    "dev:living-artifact": "vite --config web/living-artifact.vite.config.ts",
    "dev:all": "sh -c 'npm start & trap \"kill $!\" EXIT INT TERM; npm run dev'",
    "build:web": "vite build --config web/vite.config.ts",
    "build:nextbound": "vite build --config web/nextbound.vite.config.ts",
    "build:artifact": "vite build --config web/artifact.vite.config.ts",
    "build:feed": "vite build --config web/artifact-feed.vite.config.ts",
    "build:living-artifact": "vite build --config web/living-artifact.vite.config.ts",
    "build:all": "npm run build:web && npm run build:nextbound && npm run build:feed && npm run build:living-artifact",
    "build:netlify-fn": "esbuild server/netlify-mcp-entry.ts --bundle --platform=node --format=esm --outfile=netlify/functions/mcp.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "tsx server/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector http://127.0.0.1:3000/mcp",
    "test": "tsx --test server/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "validate": "tsx shared/validate.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@types/three": "^0.170.0",
    "alpinejs": "^3.15.12",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "postprocessing": "^6.39.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "zod": "^3.25.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^3.6.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
