{
  "okf_version": "0.1",
  "user_id": "<user_id>",
  "commands": [
    {
      "name": "<snake_case_command_id>",
      "intent": "<canonical natural-language query this answers>",
      "aliases": ["<other phrasing>", "<autre formulation>"],
      "resolver": {
        "type": "local",
        "source": "<file under knowledge/<user_id>/, e.g. vacation.md>",
        "locator": { "match": "<substring or regex:...>", "select": "last" },
        "op": "extract_caption"
      },
      "returns": "<one line: what the resolver yields>",
      "learned_from": "<how it was first resolved — conversation/date or source>",
      "timestamp": "<YYYY-MM-DDThh:mm:ss±hh:mm>"
    },
    {
      "name": "<mcp_backed_command_id>",
      "intent": "<query answered by live MCP data>",
      "aliases": [],
      "resolver": {
        "type": "mcp",
        "server": "<MCP server name>",
        "tool": "<MCP tool name>",
        "args": { "<param>": "<value or resolve-time input>" },
        "note": "Live data via MCP — not cached in the knowledge base."
      },
      "returns": "<one line: what the MCP call yields>",
      "learned_from": "<how it was first resolved>",
      "timestamp": "<YYYY-MM-DDThh:mm:ss±hh:mm>"
    }
  ]
}
