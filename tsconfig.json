{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "nextbound/**/*.ts",
    "web/**/*.ts",
    "web/**/*.tsx"
  ]
}
